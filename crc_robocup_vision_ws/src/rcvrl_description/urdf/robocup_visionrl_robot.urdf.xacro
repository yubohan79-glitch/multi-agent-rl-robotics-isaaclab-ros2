<?xml version="1.0"?>
<robot name="robocup_visionrl_robot" xmlns:xacro="http://www.ros.org/wiki/xacro">
  <xacro:property name="base_length" value="0.34"/>
  <xacro:property name="base_width" value="0.24"/>
  <xacro:property name="base_height" value="0.16"/>
  <xacro:property name="wheel_radius" value="0.045"/>
  <xacro:property name="wheel_width" value="0.025"/>

  <link name="base_footprint"/>

  <joint name="base_footprint_to_base_link" type="fixed">
    <parent link="base_footprint"/>
    <child link="base_link"/>
    <origin xyz="0 0 ${wheel_radius}" rpy="0 0 0"/>
  </joint>

  <link name="base_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://rcvrl_description/meshes/zoo/base_link.stl" scale="1 1 1"/>
      </geometry>
      <material name="matte_black">
        <color rgba="0.02 0.02 0.02 1.0"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 ${base_height / 2.0}" rpy="0 0 0"/>
      <geometry>
        <box size="${base_length} ${base_width} ${base_height}"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 ${base_height / 2.0}" rpy="0 0 0"/>
      <mass value="4.0"/>
      <inertia ixx="0.03" ixy="0.0" ixz="0.0" iyy="0.05" iyz="0.0" izz="0.05"/>
    </inertial>
  </link>

  <link name="left_wheel_link">
    <visual>
      <origin xyz="0 0 0" rpy="1.57079632679 0 0"/>
      <geometry>
        <cylinder radius="${wheel_radius}" length="${wheel_width}"/>
      </geometry>
      <material name="dark_gray">
        <color rgba="0.10 0.10 0.10 1.0"/>
      </material>
    </visual>
  </link>

  <joint name="left_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="left_wheel_link"/>
    <origin xyz="-0.03 ${base_width / 2.0 + wheel_width / 2.0} ${wheel_radius}" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
  </joint>

  <link name="right_wheel_link">
    <visual>
      <origin xyz="0 0 0" rpy="1.57079632679 0 0"/>
      <geometry>
        <cylinder radius="${wheel_radius}" length="${wheel_width}"/>
      </geometry>
      <material name="dark_gray">
        <color rgba="0.10 0.10 0.10 1.0"/>
      </material>
    </visual>
  </link>

  <joint name="right_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="right_wheel_link"/>
    <origin xyz="-0.03 ${-(base_width / 2.0 + wheel_width / 2.0)} ${wheel_radius}" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
  </joint>

  <link name="laser_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://rcvrl_description/meshes/zoo/laser_link.stl" scale="1 1 1"/>
      </geometry>
      <material name="lidar_blue">
        <color rgba="0.1 0.25 0.8 1.0"/>
      </material>
    </visual>
  </link>

  <joint name="laser_joint" type="fixed">
    <parent link="base_link"/>
    <child link="laser_link"/>
    <origin xyz="0.06 0 0.19" rpy="0 0 0"/>
  </joint>

  <link name="imu_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.044 0.034 0.014"/>
      </geometry>
      <material name="imu_green">
        <color rgba="0.1 0.7 0.4 1.0"/>
      </material>
    </visual>
  </link>

  <joint name="imu_joint" type="fixed">
    <parent link="base_link"/>
    <child link="imu_link"/>
    <origin xyz="-0.02 0 0.11" rpy="0 0 0"/>
  </joint>

  <link name="camera_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.035 0.025 0.025"/>
      </geometry>
      <material name="camera_black">
        <color rgba="0.01 0.01 0.01 1.0"/>
      </material>
    </visual>
  </link>

  <joint name="camera_joint" type="fixed">
    <parent link="base_link"/>
    <child link="camera_link"/>
    <origin xyz="0.18 0 0.18" rpy="0 0 0"/>
  </joint>

  <link name="depth_camera_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.034 0.024 0.024"/>
      </geometry>
      <material name="depth_camera_black">
        <color rgba="0.02 0.02 0.03 1.0"/>
      </material>
    </visual>
  </link>

  <joint name="depth_camera_joint" type="fixed">
    <parent link="base_link"/>
    <child link="depth_camera_link"/>
    <origin xyz="0.165 0.045 0.17" rpy="0 0 0"/>
  </joint>

  <link name="front_tof_left_link"/>
  <joint name="front_tof_left_joint" type="fixed">
    <parent link="base_link"/>
    <child link="front_tof_left_link"/>
    <origin xyz="0.185 0.070 0.075" rpy="0 0 0"/>
  </joint>

  <link name="front_tof_right_link"/>
  <joint name="front_tof_right_joint" type="fixed">
    <parent link="base_link"/>
    <child link="front_tof_right_link"/>
    <origin xyz="0.185 -0.070 0.075" rpy="0 0 0"/>
  </joint>

  <link name="front_bumper_contact_left_link"/>
  <joint name="front_bumper_contact_left_joint" type="fixed">
    <parent link="base_link"/>
    <child link="front_bumper_contact_left_link"/>
    <origin xyz="0.203 0.075 0.047" rpy="0 0 0"/>
  </joint>

  <link name="front_bumper_contact_right_link"/>
  <joint name="front_bumper_contact_right_joint" type="fixed">
    <parent link="base_link"/>
    <child link="front_bumper_contact_right_link"/>
    <origin xyz="0.203 -0.075 0.047" rpy="0 0 0"/>
  </joint>

  <link name="left_wheel_encoder_link"/>
  <joint name="left_wheel_encoder_joint" type="fixed">
    <parent link="left_wheel_link"/>
    <child link="left_wheel_encoder_link"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>

  <link name="right_wheel_encoder_link"/>
  <joint name="right_wheel_encoder_joint" type="fixed">
    <parent link="right_wheel_link"/>
    <child link="right_wheel_encoder_link"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>

  <link name="shooter_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 1.57079632679 0"/>
      <geometry>
        <cylinder radius="0.008" length="0.08"/>
      </geometry>
      <material name="laser_red">
        <color rgba="1.0 0.0 0.0 1.0"/>
      </material>
    </visual>
  </link>

  <joint name="shooter_joint" type="fixed">
    <parent link="base_link"/>
    <child link="shooter_link"/>
    <origin xyz="0.20 0 0.14" rpy="0 0 0"/>
  </joint>
</robot>
